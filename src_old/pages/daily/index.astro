---
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
import dailySummaries from '../../data/daily_summary_pages.json';
import pagesIndex from '../../data/pages_index.json';

const title = "Daily Summaries - ArXiv Atlas";

// Also find daily summary pages from pages_index that might not be in the
// dedicated export (e.g. pages with "daily" in slug that have page_type 'page')
const extraDaily = pagesIndex.filter((p: any) =>
  p.page_slug.includes('daily') && p.page_type !== 'daily_summary'
);

// Merge and deduplicate by slug
const slugSet = new Set(dailySummaries.map((d: any) => d.page_slug));
const allSummaries = [
  ...dailySummaries,
  ...extraDaily
    .filter((p: any) => !slugSet.has(p.page_slug))
    .map((p: any) => ({
      page_slug: p.page_slug,
      title: p.title,
      path: p.path,
      created_date: p.created_date,
    })),
].sort((a: any, b: any) => (b.created_date || '').localeCompare(a.created_date || ''));

function pageHref(slug: string) {
  return '/' + slug.replace(/^pages\//, 'pages/') + '/';
}
---
<Base title={title}>
  <Sidebar />
  <main class="page-main">
    <div class="page-header">
      <h1>Daily Summaries</h1>
      <p class="page-meta">Daily digests of newly analyzed arXiv papers</p>
    </div>

    {allSummaries.length === 0 ? (
      <p>No daily summaries have been generated yet.</p>
    ) : (
      <ul class="paper-list">
        {allSummaries.map((d: any) => (
          <li>
            <div class="paper-title">
              <a href={pageHref(d.page_slug)}>{d.title || d.page_slug}</a>
            </div>
            <div class="paper-date">{d.created_date ? d.created_date.slice(0, 10) : ''}</div>
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>
