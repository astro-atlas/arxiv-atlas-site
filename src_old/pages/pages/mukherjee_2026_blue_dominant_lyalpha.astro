      <WikiLink slug="pages/cosmic-web-gas-accretion" text="Cosmic-web gas accretion" />
      <WikiLink slug="pages/ultra-low-mass-galaxies" text="Ultra-low-mass galaxies" />
    </div>
  </main>
</Base>
