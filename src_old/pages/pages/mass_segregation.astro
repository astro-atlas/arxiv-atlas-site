import Sidebar from '../../components/Sidebar.astro';
const title = "Mass segregation";
import WikiLink from '../../components/WikiLink.astro';
---
<Base title={title}>
  <Sidebar />
  <main class="page-main">
    <h1 class="page-title">Mass segregation</h1>

    <p>Mass segregation is the tendency for massive stars (or systems) to sink toward the center of a cluster potential via dynamical friction, leading to spatial and kinematic segregation of binaries and single stars; it affects escape fractions and the composition of stars that become unbound from clusters.</p>

    <h2>Related</h2>
    <ul>
      <li><WikiLink slug="pages/zheng_2026_binary_disruption" text="Zheng et al. (2026)" /></li>
    </ul>
  </main>
</Base>
