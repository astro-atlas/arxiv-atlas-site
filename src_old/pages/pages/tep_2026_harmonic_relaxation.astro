        </tr>
        <tr>
          <th>Related concepts:</th>
          <td>
            <WikiLink slug="pages/1d_self_gravitating_systems" text="1D self-gravitating systems" /><br>
            <WikiLink slug="pages/harmonic_cores" text="Harmonic cores" /><br>
            <WikiLink slug="pages/balescu_lenard_equation" text="Balescu–Lenard equation" /><br>
