  <main class="page-main">
    <h1 class="page-title">Very long-term relaxation of harmonic 1D self-gravitating systems</h1>

    <div class="infobox">
      <h3 class="infobox-title">Very long-term relaxation of harmonic 1D self-gravitating systems</h3>
      <table>
        <tr>
          <th>Type:</th>
          <td>Paper</td>
        </tr>
        <tr>
          <th>Authors:</th>
          <td>Kerwann Tep; Jean-Baptiste Fouvry; Christophe Pichon</td>
        </tr>
        <tr>
          <th>arXiv:</th>
          <td><a href="https://arxiv.org/abs/2603.11238">arXiv:2603.11238</a></td>
        </tr>
        <tr>
