---
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
const title = "Portal:Galaxy Evolution - ArXiv Atlas";

import WikiLink from '../../components/WikiLink.astro';
---
<Base title={title}>
  <Sidebar />
  <main class="page-main">
    <h1 class="page-title">Portal: Galaxy Evolution</h1>
        
    <p>An organized entry point to articles about how galaxies form and evolve over cosmic time.</p>

    <div class="portal-section-grid">

      <div class="portal-section-card">
        <h2>Core Concepts</h2>
        <ul>
          <li><WikiLink slug="pages/Galaxy_Bimodality" text="Galaxy Bimodality" /> — The fundamental division of galaxy populations</li>
          <li><WikiLink slug="pages/Galaxy_Quenching" text="Galaxy Quenching" /> — How galaxies stop forming stars</li>
          <li><WikiLink slug="pages/Star_Formation_Main_Sequence" text="Star Formation Main Sequence" /> — The SFR–mass relation</li>
          <li><WikiLink slug="pages/Galaxy_Scaling_Relations" text="Galaxy Scaling Relations" /> — Fundamental correlations</li>
          <li><WikiLink slug="pages/Galaxy_Mergers" text="Galaxy Mergers" /> — Gravitational interactions</li>
          <li><WikiLink slug="pages/Downsizing" text="Downsizing" /> — Mass-dependent evolution</li>
          <li><WikiLink slug="pages/Chemical_Evolution" text="Chemical Evolution" /> — Metallicity buildup</li>
          <li><WikiLink slug="pages/Morphological_Evolution" text="Morphological Evolution" /> — Structural changes</li>
        </ul>
      </div>

      <div class="portal-section-card">
        <h2>Observational Tools</h2>
        <ul>
          <li><WikiLink slug="pages/Color-Magnitude_Diagram" text="Color-Magnitude Diagram" /> — Key diagnostic plot</li>
          <li><WikiLink slug="pages/UVJ_Diagram" text="UVJ Diagram" /> — Dust-robust classification</li>
          <li><WikiLink slug="pages/BPT_Diagram" text="BPT Diagram" /> — Emission line diagnostics</li>
          <li><WikiLink slug="pages/Fundamental_Plane" text="Fundamental Plane" /> — Early-type galaxy relations</li>
          <li><WikiLink slug="pages/Tully-Fisher_Relation" text="Tully-Fisher Relation" /> — Disk galaxy scaling</li>
        </ul>
      </div>

      <div class="portal-section-card">
        <h2>Quenching Mechanisms</h2>
        <p class="portal-section-sub">Internal</p>
        <ul>
          <li><WikiLink slug="pages/Morphological_Quenching" text="Morphological Quenching" /> — Bulge-driven suppression</li>
          <li><WikiLink slug="pages/Mass_Quenching" text="Mass Quenching" /> — Mass-dependent shutdown</li>
          <li><WikiLink slug="pages/AGN_Feedback" text="AGN Feedback" /> — Black hole driven winds</li>
          <li><WikiLink slug="pages/Stellar_Feedback" text="Stellar Feedback" /> — Supernovae and stellar winds</li>
          <li><WikiLink slug="pages/Halo_Quenching" text="Halo Quenching" /> — Virial shock heating</li>
        </ul>
        <p class="portal-section-sub">Environmental</p>
        <ul>
          <li><WikiLink slug="pages/Ram_Pressure_Stripping" text="Ram Pressure Stripping" /> — Gas removal in clusters</li>
          <li><WikiLink slug="pages/Strangulation" text="Strangulation" /> — Cutting off gas supply</li>
          <li><WikiLink slug="pages/Galaxy_Harassment" text="Galaxy Harassment" /> — Repeated encounters</li>
          <li><WikiLink slug="pages/Preprocessing" text="Preprocessing" /> — Group environment effects</li>
          <li><WikiLink slug="pages/Tidal_Stripping" text="Tidal Stripping" /> — Gravitational mass loss</li>
        </ul>
      </div>

      <div class="portal-section-card">
        <h2>Galaxy Types</h2>
        <p class="portal-section-sub">By Morphology</p>
        <ul>
          <li><WikiLink slug="pages/Elliptical_Galaxies" text="Elliptical Galaxies" /> — Smooth, red systems</li>
          <li><WikiLink slug="pages/Spiral_Galaxies" text="Spiral Galaxies" /> — Disk-dominated with arms</li>
          <li><WikiLink slug="pages/S0_Galaxies" text="S0/Lenticular Galaxies" /> — Transition type</li>
          <li><WikiLink slug="pages/Irregular_Galaxies" text="Irregular Galaxies" /> — No clear structure</li>
          <li><WikiLink slug="pages/Dwarf_Galaxies" text="Dwarf Galaxies" /> — Low-mass systems</li>
        </ul>
        <p class="portal-section-sub">By Activity</p>
        <ul>
          <li><WikiLink slug="pages/Star-Forming_Galaxies" text="Star-Forming Galaxies" /> — Active star formation</li>
          <li><WikiLink slug="pages/Quiescent_Galaxies" text="Quiescent Galaxies" /> — Little/no star formation</li>
          <li><WikiLink slug="pages/Starburst_Galaxies" text="Starburst Galaxies" /> — Extreme star formation</li>
          <li><WikiLink slug="pages/Active_Galactic_Nuclei" text="Active Galactic Nuclei" /> — Accreting black holes</li>
          <li><WikiLink slug="pages/Post-Starburst_Galaxies" text="Post-Starburst Galaxies" /> — Recently quenched</li>
        </ul>
      </div>

      <div class="portal-section-card">
        <h2>Key Surveys &amp; Instruments</h2>
        <ul>
          <li><WikiLink slug="pages/SDSS" text="Sloan Digital Sky Survey (SDSS)" /></li>
          <li><WikiLink slug="pages/GAMA" text="Galaxy And Mass Assembly (GAMA)" /></li>
          <li><WikiLink slug="pages/COSMOS" text="Cosmic Evolution Survey (COSMOS)" /></li>
          <li><WikiLink slug="pages/CANDELS" text="CANDELS" /> — Deep HST survey</li>
          <li><WikiLink slug="pages/ALMA" text="ALMA" /> — Submm/molecular gas</li>
          <li><WikiLink slug="pages/JWST" text="James Webb Space Telescope" /></li>
          <li><WikiLink slug="pages/Rubin_LSST" text="Vera Rubin Observatory (LSST)" /></li>
        </ul>
      </div>

      <div class="portal-section-card">
        <h2>Theoretical Framework</h2>
        <ul>
          <li><WikiLink slug="pages/Lambda-CDM" text="ΛCDM Cosmology" /> — Standard model</li>
          <li><WikiLink slug="pages/Dark_Matter_Halos" text="Dark Matter Halos" /> — Galaxy hosts</li>
          <li><WikiLink slug="pages/Hierarchical_Structure_Formation" text="Hierarchical Structure Formation" /></li>
          <li><WikiLink slug="pages/Semi-Analytic_Models" text="Semi-Analytic Models (SAMs)" /></li>
          <li><WikiLink slug="pages/Hydrodynamical_Simulations" text="Hydrodynamical Simulations" /></li>
          <li><WikiLink slug="pages/Subgrid_Physics" text="Subgrid Physics" /> — Unresolved processes</li>
        </ul>
      </div>

      <div class="portal-section-card portal-section-card--full">
        <h2>Major Open Questions</h2>
        <ul>
          <li>What drives <WikiLink slug="pages/Galaxy_Bimodality" text="galaxy bimodality" />?</li>
          <li>How do galaxies <WikiLink slug="pages/Size_Evolution" text="grow in size" /> at fixed mass?</li>
          <li>What regulates the <WikiLink slug="pages/Galaxy-Halo_Connection" text="galaxy-halo connection" />?</li>
          <li>How do <WikiLink slug="pages/Supermassive_Black_Holes" text="supermassive black holes" /> co-evolve with their hosts?</li>
          <li>What causes <WikiLink slug="pages/Scatter_in_Scaling_Relations" text="scatter in scaling relations" />?</li>
          <li>How important is <WikiLink slug="pages/Secular_Evolution" text="secular evolution" /> relative to mergers?</li>
        </ul>
      </div>

    </div>

    <div class="page-tags">
      <strong>Tags:</strong>
      <WikiLink slug="pages/Tag_Portal" text="Portal" />
      <WikiLink slug="pages/Tag_Galaxy_Evolution" text="Galaxy Evolution" />
    </div>
  </main>
</Base>
