---
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
const title = "Binary survival fraction";
import WikiLink from '../../components/WikiLink.astro';
---
<Base title={title}>
  <Sidebar />
  <main class="page-main">
    <h1 class="page-title">Binary survival fraction</h1>

    <p>The binary survival fraction quantifies the fraction of primordial binaries that remain bound in a stellar system as a function of time, cluster density, and binary parameters (period, mass ratio q, eccentricity e).</p>

    <h2>Links</h2>
    <ul>
      <li><WikiLink slug="pages/zheng_2026_binary_disruption" text="Zheng et al. (2026)" /> — Predictive model and Python tool for survival fractions.</li>
    </ul>
  </main>
</Base>
