---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a class="site-logo" href="/">
        <span class="logo-icon">α</span>ArXiv Atlas
      </a>
      <div class="header-actions">
        <form class="search-form" id="searchForm" role="search" autocomplete="off">
          <i class="fa-solid fa-magnifying-glass search-icon"></i>
          <input type="text" id="searchInput" placeholder="Search pages…" aria-label="Search pages">
          <ul class="search-results" id="searchResults"></ul>
        </form>
        <a class="header-btn" href="/random" title="Random page">
          <i class="fa-solid fa-shuffle"></i>
        </a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <i class="fa-solid fa-sun" id="themeIcon"></i>
        </button>
      </div>
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </header>

  <div class="page-layout">
    <slot />
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <span>ArXiv Atlas — Galaxy Evolution Knowledge Portal</span>
      <span class="footer-sep">·</span>
      <span class="footer-muted">Built for Sai · 2026</span>
    </div>
  </footer>

  <script>
    // Theme toggle
    const html = document.documentElement;
    const stored = localStorage.getItem('atlas-theme');
    if (stored === 'dark' || stored === 'light') html.setAttribute('data-theme', stored);

    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');
      if (!btn || !icon) return;

      function applyIcon() {
        const dark = html.getAttribute('data-theme') === 'dark';
        icon.className = dark ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
      }
      applyIcon();

      btn.addEventListener('click', () => {
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('atlas-theme', next);
        applyIcon();
      });

      // Mobile sidebar
      const menuBtn = document.getElementById('mobileMenuBtn');
      const sidebar = document.querySelector('.page-sidebar');
      if (menuBtn && sidebar) {
        menuBtn.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
          if (sidebar.classList.contains('open') &&
              !sidebar.contains(e.target as Node) &&
              !menuBtn.contains(e.target as Node)) {
            sidebar.classList.remove('open');
          }
        });
      }

      // Auto-generate TOC
      const tocNav = document.getElementById('toc-nav');
      const article = document.querySelector('.page-main');
      if (tocNav && article) {
        const headings = article.querySelectorAll('h2, h3');
        headings.forEach((h, i) => {
          if (!h.id) h.id = 'section-' + i;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          if (h.tagName === 'H3') a.style.paddingLeft = '20px';
          li.appendChild(a);
          tocNav.appendChild(li);
        });

        const obs = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocNav.querySelectorAll('a').forEach(a => a.classList.remove('active'));
              const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
              if (link) link.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });
        headings.forEach(h => obs.observe(h));
      }

      // Smooth scroll for anchor links
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement).closest('a[href^="#"]');
        if (!a) return;
        const target = document.querySelector(a.getAttribute('href')!);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>

  <script>
    // Red-link detection: fetch existing slugs once, then mark missing pages
    let slugSetPromise: Promise<Set<string>> | null = null;
    function getSlugSet() {
      if (!slugSetPromise) {
        slugSetPromise = fetch('/existing-slugs.json')
          .then(r => r.json())
          .then((items: {slug: string, title: string}[]) => new Set(items.map(item => item.slug.replace(/[-\s]/g, '-').toLowerCase())));
      }
      return slugSetPromise;
    }

    function markRedLinks() {
      getSlugSet().then(slugSet => {
        document.querySelectorAll<HTMLAnchorElement>('a[href^="/pages/"]').forEach(a => {
          const raw = a.getAttribute('href')!.replace(/\/+$/, '');
          const m = raw.match(/^\/pages\/([^/]+)$/);
          if (m) {
            const slug = m[1].toLowerCase();
            if (!slugSet.has(slug)) a.classList.add('redlink');
          }
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', markRedLinks);
    } else {
      markRedLinks();
    }
  </script>

  <script>
    // Client-side search: lazy-load index from static JSON on first interaction
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('searchInput') as HTMLInputElement | null;
      const results = document.getElementById('searchResults');
      const form = document.getElementById('searchForm');
      if (!input || !results || !form) return;

      let entries: {title: string; slug: string}[] | null = null;
      let activeIdx = -1;

      async function loadIndex() {
        if (entries) return entries;
        const res = await fetch('/search-index.json');
        entries = await res.json();
        return entries!;
      }

      function render(matches: {title: string; slug: string}[]) {
        results.innerHTML = '';
        activeIdx = -1;
        if (matches.length === 0) {
          results.style.display = 'none';
          return;
        }
        results.style.display = 'block';
        matches.slice(0, 12).forEach((m, i) => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '/' + m.slug;
          a.textContent = m.title;
          a.setAttribute('data-idx', String(i));
          li.appendChild(a);
          results.appendChild(li);
        });
      }

      function setActive(idx: number) {
        const items = results.querySelectorAll('a');
        items.forEach(a => a.classList.remove('active'));
        if (idx >= 0 && idx < items.length) {
          items[idx].classList.add('active');
          activeIdx = idx;
        } else {
          activeIdx = -1;
        }
      }

      input.addEventListener('input', async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) { render([]); return; }
        const data = await loadIndex();
        const matches = data.filter(e =>
          e.title.toLowerCase().includes(q)
        ).sort((a, b) => {
          const ai = a.title.toLowerCase().indexOf(q);
          const bi = b.title.toLowerCase().indexOf(q);
          return ai - bi;
        });
        render(matches);
      });

      input.addEventListener('keydown', (e) => {
        const items = results.querySelectorAll('a');
        if (!items.length) return;
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(Math.min(activeIdx + 1, items.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(Math.max(activeIdx - 1, 0));
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIdx >= 0 && items[activeIdx]) {
            window.location.href = (items[activeIdx] as HTMLAnchorElement).href;
          } else if (items.length > 0) {
            window.location.href = (items[0] as HTMLAnchorElement).href;
          }
        } else if (e.key === 'Escape') {
          render([]);
          input.blur();
        }
      });

      document.addEventListener('click', (e) => {
        if (!form.contains(e.target as Node)) render([]);
      });

      input.addEventListener('focus', () => {
        if (input.value.trim()) input.dispatchEvent(new Event('input'));
      });
    });
  </script>

  <script>
    // Reference link handler: expand References section and pan to it
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#ref"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const refId = link.getAttribute('href');
          if (!refId) return;

          // Find references section (both collapsible and non-collapsible)
          const refSection = document.querySelector('.references') || document.querySelector('details.references');
          if (refSection) {
            // If it's a collapsible <details>, open it
            if (refSection instanceof HTMLDetailsElement) {
              refSection.open = true;
            }
            // Scroll to references section
            refSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          // Also scroll to the specific reference if it exists
          const targetRef = document.querySelector(refId);
          if (targetRef) {
            setTimeout(() => {
              targetRef.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              targetRef.classList.add('highlight');
              setTimeout(() => targetRef.classList.remove('highlight'), 2000);
            }, 300);
          }
        });
      });
    });
  </script>

  <style>
    /* Highlight animation for referenced items */
    @keyframes highlight-pulse {
      0% { background-color: transparent; }
      50% { background-color: var(--c-accent-light); }
      100% { background-color: transparent; }
    }
    .references li.highlight {
      animation: highlight-pulse 1.5s ease-in-out;
    }
  </style>
</body>
</html>
