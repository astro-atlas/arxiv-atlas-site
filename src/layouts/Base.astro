---
interface Props {
  title: string;
}
const { title } = Astro.props;

// Build-time: collect all existing page slugs
const pageFiles = import.meta.glob('../pages/pages/*.astro');
const existingSlugs = Object.keys(pageFiles)
  .map(p => p.split('/').pop()!.replace('.astro', ''))
  .filter(s => !s.startsWith('_'));
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a class="site-logo" href="/">
        <span class="logo-icon">α</span>ArXiv Atlas
      </a>
      <div class="header-tracker">
        <span class="tracker-item"><strong>22</strong> pages</span>
        <span class="tracker-sep">·</span>
        <span class="tracker-item"><strong>3</strong> papers</span>
      </div>
      <div class="header-actions">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <i class="fa-solid fa-sun" id="themeIcon"></i>
        </button>
      </div>
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </header>

  <div class="page-layout">
    <slot />
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <span>ArXiv Atlas — Galaxy Evolution Knowledge Portal</span>
      <span class="footer-sep">·</span>
      <span class="footer-muted">Built for Sai · 2026</span>
    </div>
  </footer>

  <script>
    // Theme toggle
    const html = document.documentElement;
    const stored = localStorage.getItem('atlas-theme');
    if (stored === 'dark' || stored === 'light') html.setAttribute('data-theme', stored);

    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');
      if (!btn || !icon) return;

      function applyIcon() {
        const dark = html.getAttribute('data-theme') === 'dark';
        icon.className = dark ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
      }
      applyIcon();

      btn.addEventListener('click', () => {
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('atlas-theme', next);
        applyIcon();
      });

      // Mobile sidebar
      const menuBtn = document.getElementById('mobileMenuBtn');
      const sidebar = document.querySelector('.page-sidebar');
      if (menuBtn && sidebar) {
        menuBtn.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
          if (sidebar.classList.contains('open') &&
              !sidebar.contains(e.target as Node) &&
              !menuBtn.contains(e.target as Node)) {
            sidebar.classList.remove('open');
          }
        });
      }

      // Auto-generate TOC
      const tocNav = document.getElementById('toc-nav');
      const article = document.querySelector('.page-main');
      if (tocNav && article) {
        const headings = article.querySelectorAll('h2, h3');
        headings.forEach((h, i) => {
          if (!h.id) h.id = 'section-' + i;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          if (h.tagName === 'H3') a.style.paddingLeft = '20px';
          li.appendChild(a);
          tocNav.appendChild(li);
        });

        const obs = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocNav.querySelectorAll('a').forEach(a => a.classList.remove('active'));
              const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
              if (link) link.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });
        headings.forEach(h => obs.observe(h));
      }

      // Smooth scroll for anchor links
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement).closest('a[href^="#"]');
        if (!a) return;
        const target = document.querySelector(a.getAttribute('href')!);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>

  <script define:vars={{ existingSlugs }}>
    // Auto-mark links to non-existent pages as red
    // Normalize: strip trailing slash, compare slug against existingSlugs set
    const slugSet = new Set((existingSlugs as string[]).map(s => s.replace(/[-\s]/g, '-').toLowerCase()));
    function markRedLinks() {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="/pages/"]').forEach(a => {
        const raw = a.getAttribute('href')!.replace(/\/+$/, ''); // strip trailing slash
        const m = raw.match(/^\/pages\/([^/]+)$/);
        if (m) {
          const slug = m[1].toLowerCase();
          if (!slugSet.has(slug)) {
            a.classList.add('redlink');
          }
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', markRedLinks);
    } else {
      markRedLinks();
    }
  </script>
</body>
</html>
