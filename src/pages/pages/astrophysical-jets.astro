    <div class="infobox">
      <h3 class="infobox-title">Astrophysical Jets</h3>
      <table>
        <tr><th>Type:</th><td>Concept</td></tr>
        <tr><th>Educational level:</th><td>Undergraduate</td></tr>
        <tr><th>Key Papers:</th><td><WikiLink slug="pages/Bromberg_2011" text="Bromberg et al. (2011)" /></td></tr>
