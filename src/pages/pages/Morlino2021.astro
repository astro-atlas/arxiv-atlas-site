      <table>
        <tr><th>Type:</th><td>Paper</td></tr>
        <tr><th>DOI:</th><td><a href="https://doi.org/10.1093/mnras/stab690">10.1093/mnras/stab690</a></td></tr>
        <tr><th>Topic:</th><td>Particle transport at wind termination shocks; semi-analytic iterative methods</td></tr>
      </table>
