      <table>
        <tr><th>Type:</th><td>Paper (review)</td></tr>
        <tr><th>DOI:</th><td><a href="https://doi.org/10.1146/annurev.aa.22.090184.002233">10.1146/annurev.aa.22.090184.002233</a></td></tr>
        <tr><th>Topic:</th><td>Origin of ultra-high-energy cosmic rays; Hillas criterion for maximum particle energy</td></tr>
      </table>
