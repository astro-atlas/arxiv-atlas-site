---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import WikiLink from '../components/WikiLink.astro';
import stats from '../data/stats.json';
import pagesIndex from '../data/pages_index.json';

const title = "ArXiv Atlas - Galaxy Evolution Knowledge Portal";

// Get the 3 most recent paper pages
const recentPaperPages = pagesIndex
  .filter((p: any) => p.page_type === 'paper' && p.page_slug !== 'papers/index')
  .sort((a: any, b: any) => (b.created_date || '').localeCompare(a.created_date || ''))
  .slice(0, 3);

const latestPaper = recentPaperPages.filter((p: any) => p.page_slug !== 'papers/index')[0];

// Get the most recent daily summary
const latestDaily = pagesIndex
  .filter((p: any) => p.page_type === 'daily_summary')
  .sort((a: any, b: any) => (b.page_slug || '').localeCompare(a.page_slug || ''))[0];

const latestDailyHref = latestDaily ? '/' + latestDaily.page_slug + '/' : null;
const latestDailyLabel = latestDaily
  ? (latestDaily.title || '').replace(/^Daily Summary\s*—\s*/i, '')
  : null;

// Derive URL from file path when available, fall back to slug
// Canonical URLs use no trailing slash (both /pages/X and /pages/X/ work in Astro)
function pageHref(p: any) {
  const slug = (p.page_slug || '').replace(/^papers\//, '');
  return '/pages/' + slug;
}
---
<Base title={title}>
  <Sidebar />
  <main class="page-main">
    <div class="hero-splash">
      <div class="hero-content">
        <div class="hero-badge">Galaxy Evolution Research</div>
        <h1>ArXiv Atlas</h1>
        <p class="hero-tagline">A living knowledge web of the astrophysical literature — one paper at a time</p>
        
        <div class="hero-counters">
          <a href="/papers/" class="counter-pill">
            <span class="counter-icon">📄</span>
            <span class="counter-value">{stats.total_papers}</span>
            <span class="counter-label">papers</span>
          </a>
          <a href="/pages/portal-particle-acceleration-in-jets/" class="counter-pill">
            <span class="counter-icon">📚</span>
            <span class="counter-value">{stats.total_pages}</span>
            <span class="counter-label">pages</span>
          </a>
        </div>
      </div>
      
      {latestPaper && (
        <div class="hero-latest">
          <div class="latest-label">Latest Addition</div>
          <a href={pageHref(latestPaper)} class="latest-paper">
            <span class="latest-title">{latestPaper.title}</span>
            <span class="latest-meta">{latestPaper.created_date ? latestPaper.created_date.slice(0, 10) : ''}</span>
          </a>
        </div>
      )}
      
      <div class="hero-actions">
        {latestDailyHref && (
          <a class="hero-btn primary" href={latestDailyHref}>📰 Daily Summary — {latestDailyLabel}</a>
        )}
        <a class="hero-btn secondary wikilink" href="/portals/">Browse Portals →</a>
        <a class="hero-btn secondary wikilink" href="/random/">Random Article</a>
      </div>
    </div>

        <h2 id="section-0">About This Wiki</h2>
        
        <p>ArXiv Atlas is a knowledge portal for galaxy evolution research. Unlike traditional paper databases, we:</p>
        
        <ul>
            <li><strong>Connect concepts:</strong> Every paper links to relevant concepts, and concepts link to each other</li>
            <li><strong>Track claims:</strong> Papers are summarized with their key claims and evidence</li>
            <li><strong>Show disagreements:</strong> When papers contradict, we note it</li>
            <li><strong>Stay current:</strong> Daily updates from astro-ph.GA</li>
        </ul>

        <h2 id="section-1">Recently Analyzed Papers</h2>
        
        <ul class="paper-list">
            {recentPaperPages.map((p: any) => (
              <li>
                <div class="paper-title">
                  <a href={pageHref(p)}>{p.title || p.page_slug}</a>
                </div>
                <div class="paper-date">{p.created_date ? p.created_date.slice(0, 10) : ''}</div>
              </li>
            ))}
        </ul>
  </main>
</Base>
